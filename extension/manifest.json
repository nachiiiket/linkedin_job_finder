{
  "manifest_version": 3,
  "name": "LinkedIn Job Finder",
  "version": "1.0.0",
  "description": "Scrape LinkedIn job listings, track applications, and export to Excel.",
  "permissions": ["storage", "downloads", "tabs", "notifications"],
  "host_permissions": ["https://*.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Job Finder",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["utils/storage.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
